# =============================================================================
# 飞书知识库博客配置
# =============================================================================
# 配置说明：
# 1. 先在飞书开放平台创建企业自建应用
# 2. 在飞书中创建知识库，并获取 Token
# 3. 在知识库中创建「博客」文件夹，存放博客文章
# 4. 将以下配置填入 .env 文件
# =============================================================================

# -----------------------------------------------------------------------------
# 飞书开放平台应用配置
# 获取地址：https://open.feishu.cn/app
# -----------------------------------------------------------------------------

# 应用 ID（创建应用后获得）
VITE_FEISHU_APP_ID=cli_xxxxxxxxxxxx

# 应用 Secret（创建应用后获得）
# ⚠️ 注意：生产环境应通过后端代理，不要在前端直接暴露此密钥
VITE_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 飞书知识库配置
# -----------------------------------------------------------------------------

# 知识库 Token（从知识库 URL 获取）
# 例如：https://xxx.feishu.cn/wiki/XXXXXX 中的 XXXXXX
VITE_FEISHU_WIKI_TOKEN=xxxxxxxxxxxx

# 博客文件夹 Token（可选，用于指定博客存放的文件夹）
# 如果不设置，将获取知识库根目录下的所有文档
# 获取方式：在飞书知识库中右键点击文件夹 -> 复制链接 -> 提取 node_token 参数
VITE_FEISHU_BLOG_FOLDER_TOKEN=xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 数据源配置
# -----------------------------------------------------------------------------

# 数据源模式
# - feishu: 仅使用飞书知识库数据源（需要正确配置飞书参数）
# - static: 仅使用静态数据（无需后端服务，适合纯静态部署）
# - auto: 优先飞书，失败时降级到静态数据（默认，推荐）
VITE_DATA_SOURCE_MODE=auto

# -----------------------------------------------------------------------------
# 缓存配置
# -----------------------------------------------------------------------------

# 缓存时长（分钟，默认 10）
# 飞书 API 有调用频率限制，建议开启缓存
VITE_CACHE_DURATION=10

# -----------------------------------------------------------------------------
# 后端代理配置（可选）
# -----------------------------------------------------------------------------

# 后端代理服务器地址
# 如果使用后端代理处理飞书 API 请求，请设置此项
# 例如：http://localhost:3001 或 https://your-api-server.com
# VITE_API_BASE_URL=http://localhost:3001